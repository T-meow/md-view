{
  "name": "md-view",
  "version": "0.2.3",
  "description": "Local Markdown reader and editor built with Tauri and Svelte.",
  "license": "WTFPL",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.app.config.mjs --configLoader runner --host 127.0.0.1 --port 1420",
    "build": "vite build --config vite.app.config.mjs --configLoader runner",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --bundles nsis",
    "tauri:build:all": "tauri build",
    "tauri:build:no-bundle": "tauri build --no-bundle"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.2.4",
    "marked": "^15.0.7",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.2",
    "@tsconfig/svelte": "^5.0.4",
    "esbuild": "^0.27.2",
    "svelte-check": "^4.1.4",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "vite": "^8.0.16"
  }
}
